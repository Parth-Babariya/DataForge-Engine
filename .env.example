# ============================================================================
# DATAFORGE ENGINE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains secrets!
# ============================================================================

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-actual-api-key-here

# LLM Model Selection (gpt-4o, gpt-4, gpt-3.5-turbo, etc.)
LLM_MODEL=gpt-3.5-turbo

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# Directory where generated datasets (JSONL files) are stored
DATASET_BASE_DIR=datasets

# Minimum character length for question/answer fields (validation)
VALIDATOR_MIN_LENGTH=10

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# FastAPI server host and port (Docker uses these)
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit server port
UI_PORT=8501

# ============================================================================
# OPTIONAL: FUTURE INTEGRATIONS
# ============================================================================

# Anthropic Claude API (for multi-provider support)
# ANTHROPIC_API_KEY=sk-ant-...

# Database URL (for SQLite/PostgreSQL integration)
# DATABASE_URL=sqlite:///./datasets.db

# Redis URL (for caching layer)
# REDIS_URL=redis://localhost:6379/0
